<Application x:Class="ServisVozila.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ServisVozila"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="/Views/LoginView.xaml">
    <Application.Resources>
        <!-- Merging external ResourceDictionary -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Define the ButtonSelectBrush -->
            <SolidColorBrush x:Key="ButtonSelectBrush" Color="#FFB3E5FC" />
            <!-- Example light blue -->

            <!-- Define the DarkBrush -->
            <SolidColorBrush x:Key="DarkBrush" Color="#FF0288D1" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
